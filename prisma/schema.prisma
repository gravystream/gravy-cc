// ============================================================
// GRAVY COMMAND CENTER  Database Schema
// Creator Marketplace Platform
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & USERS
// ============================================================

enum UserRole {
  CREATOR
  BRAND
  OWNER
  ADMINISTRATOR
  TECHNICAL
  SUPPORT
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  TRIAL
  EXPIRED
}

model User {
  // back-relations added for chat
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CREATOR)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  creatorProfile CreatorProfile?
  brandProfile   BrandProfile?
  notifications Notification[]
  subscription Subscription?
  resetTokens    PasswordResetToken[]

  @@index([email])
  @@index([role])
  sentMessages    Message[]  @relation(name: "MessageSender")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ============================================================
// SUBSCRIPTION
// ============================================================

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               SubscriptionStatus @default(TRIAL)
  plan                 String
  amount               Int
  currency             String             @default("NGN")
  paystackSubscriptionId String?          @unique
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  trialEnd             DateTime?
  pausedAt             DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================================
// CREATOR PROFILE
// ============================================================

enum CreatorAvailability {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

model CreatorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username    String   @unique
  displayName String
  bio         String?
  tagline     String?
  avatarUrl   String?
  coverUrl    String?
  location    String?
  languages   String[] @default([])
  niches      String[] @default([])
  platforms   String[] @default([])

  baseRateKobo  Int     @default(0)
  currency      String  @default("NGN")
  availability  CreatorAvailability @default(AVAILABLE)
  isVerified    Boolean @default(false)

  totalJobsCompleted  Int     @default(0)
  totalEarningsKobo   Int     @default(0)
  avgRating           Float   @default(0)
  totalReviews        Int     @default(0)
  responseTimeHours   Float   @default(24)

  portfolioVideos PortfolioVideo[]
  proposals       Proposal[]
  directHireOffers DirectHireOffer[]
  jobs            Job[]
  wallet          Wallet?

  tiktokUrl     String?
  instagramUrl  String?
  youtubeUrl    String?
  twitterUrl    String?

  // AI Portfolio Scoring
  portfolioAiScore    Int?
  portfolioAiFeedback String?
  portfolioAiCheckedAt DateTime?

    createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@index([niches])
  @@index([location])
  @@index([avgRating])
  @@index([availability])
  conversations   Conversation[]
  contracts         Contract[]    @relation(name: "CreatorContracts")
  escrowPayments    ContractEscrow[] @relation(name: "CreatorContractEscrows")
  videoSubmissions  VideoSubmission[] @relation(name: "CreatorVideoSubs")
  shortlists    Shortlist[]
}

model PortfolioVideo {
  id              String  @id @default(cuid())
  creatorId       String
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  cloudinaryId    String
  cloudinaryUrl   String
  thumbnailUrl    String?
  durationSeconds Int?
  views           Int     @default(0)
  isFeatured      Boolean @default(false)
  order           Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([creatorId])
}

// ============================================================
// BRAND PROFILE
// ============================================================

model BrandProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  slug         String   @unique
  description  String?
  logoUrl      String?
  websiteUrl   String?
  industry     String?
  location     String?

  totalCampaigns     Int @default(0)
  totalSpentKobo     Int @default(0)
  avgCreatorRating   Float @default(0)

  campaigns         Campaign[]
  directHireOffers  DirectHireOffer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([industry])
  conversations   Conversation[]
  brandWallet       BrandWallet?
  contracts         Contract[]     @relation(name: "BrandContracts")
  escrowPayments    ContractEscrow[] @relation(name: "BrandContractEscrows")
  shortlists    Shortlist[]
}

// ============================================================
// CAMPAIGNS & BRIEFS
// ============================================================

enum CampaignType {
  OPEN
  DIRECT_HIRE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  REVIEWING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Campaign {
  id              String         @id @default(cuid())
  brandId         String
  brand           BrandProfile   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  title           String
  description     String
  requirements    String
  deliverables    String[]       @default([])
  niche           String[]       @default([])
  platforms       String[]       @default([])
  type            CampaignType   @default(OPEN)
  status          CampaignStatus @default(DRAFT)

  budgetKobo      Int
  currency        String         @default("NGN")
  deadline        DateTime
  revisionCount   Int            @default(1)

  escrow          Escrow?
  proposals       Proposal[]
  viewCount       Int            @default(0)
  proposalCount   Int            @default(0)
  qualifiedCount  Int            @default(0)
  directHireOffer DirectHireOffer?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([status])
  @@index([type])
  @@index([niche])
  @@index([deadline])
  conversations   Conversation[]
  contracts         Contract[]
}

// ============================================================
// PROPOSALS
// ============================================================

enum ProposalStatus {
  SUBMITTED
  UNDER_AI_REVIEW
  QUALIFIED
  NOT_QUALIFIED
  SHORTLISTED
  SELECTED
  REJECTED
  WITHDRAWN
}

model Proposal {
  id          String         @id @default(cuid())
  campaignId  String
  campaign    Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorId   String
  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  status      ProposalStatus @default(SUBMITTED)

  pitchCloudinaryId  String?
  pitchCloudinaryUrl String?
  pitchThumbnailUrl  String?
  pitchDurationSecs  Int?

  coverLetter     String?
  proposedBudget  Int?
  proposedTimeline Int?

  aiScore          Float?
  aiVideoScore     Float?
  aiAudioScore     Float?
  aiRelevanceScore Float?
  aiFeedback       String?
  aiCheckedAt      DateTime?

  job Job?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, creatorId])
  @@index([campaignId])
  @@index([creatorId])
  @@index([status])
  @@index([aiScore])
}

// ============================================================
// DIRECT HIRE
// ============================================================

enum DirectHireStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model DirectHireOffer {
  id          String           @id @default(cuid())
  brandId     String
  brand       BrandProfile     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  creatorId   String
  creator     CreatorProfile   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  campaignId  String?          @unique
  campaign    Campaign?        @relation(fields: [campaignId], references: [id])
  status      DirectHireStatus @default(PENDING)
  message     String?
  budgetKobo  Int
  deadline    DateTime
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([brandId])
  @@index([creatorId])
  @@index([status])
}

// ============================================================
// JOBS
// ============================================================

enum JobStatus {
  AWAITING_PAYMENT
  IN_PROGRESS
  DELIVERED
  UNDER_AI_REVIEW
  REVISION_REQUESTED
  APPROVED
  PAID
  DISPUTED
  CANCELLED
}

model Job {
  id           String         @id @default(cuid())
  proposalId   String?        @unique
  proposal     Proposal?      @relation(fields: [proposalId], references: [id])
  creatorId    String
  creator      CreatorProfile @relation(fields: [creatorId], references: [id])
  campaignId   String
  status       JobStatus      @default(IN_PROGRESS)
  deadline     DateTime
  revisionLeft Int            @default(1)

  deliverables JobDeliverable[]
  escrowId     String?
  review       Review?
  autoReleaseAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
  @@index([campaignId])
  @@index([status])
}

model JobDeliverable {
  id              String   @id @default(cuid())
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cloudinaryId    String
  cloudinaryUrl   String
  thumbnailUrl    String?
  durationSeconds Int?
  fileSize        Int?
  isLatest        Boolean  @default(true)

  aiScore          Float?
  aiVideoScore     Float?
  aiAudioScore     Float?
  aiRelevanceScore Float?
  aiFeedback       String?
  aiCheckedAt      DateTime?

  revisionNumber  Int      @default(1)
  createdAt       DateTime @default(now())

  @@index([jobId])
}

// ============================================================
// ESCROW PAYMENTS
// ============================================================

enum EscrowStatus {
  PENDING_DEPOSIT
  FUNDED
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

model Escrow {
  id             String       @id @default(cuid())
  campaignId     String       @unique
  campaign       Campaign     @relation(fields: [campaignId], references: [id])
  amountKobo     Int
  currency       String       @default("NGN")
  status         EscrowStatus @default(PENDING_DEPOSIT)
  platformFeeKobo Int
  feePercent      Float        @default(10.0)

  paystackRef    String?      @unique
  stripeRef      String?      @unique

  releasedAt     DateTime?
  releasedToId   String?
  disputeReason  String?
  disputedAt     DateTime?
  resolvedAt     DateTime?
  resolvedBy     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ============================================================
// WALLETS & PAYOUTS
// ============================================================

enum WalletTransactionType {
  CREDIT_PAYMENT
  DEBIT_WITHDRAWAL
  DEBIT_FEE
  CREDIT_REFUND
  DEBIT_DISPUTE
}

model Wallet {
  id              String         @id @default(cuid())
  creatorId       String         @unique
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  balanceKobo     Int            @default(0)
  pendingKobo     Int            @default(0)
  currency        String         @default("NGN")

  bankName        String?
  bankCode        String?
  accountNumber   String?
  accountName     String?
  paystackRecipientCode String?

  transactions    WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id            String                @id @default(cuid())
  walletId      String
  wallet        Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          WalletTransactionType
  amountKobo    Int
  description   String
  reference     String?
  jobId         String?
  createdAt     DateTime              @default(now())

  @@index([walletId])
  @@index([type])
}

// ============================================================
// REVIEWS & RATINGS
// ============================================================

model Review {
  id          String  @id @default(cuid())
  jobId       String  @unique
  job         Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId    String
  subjectId   String
  overallRating  Int
  qualityRating  Int?
  communicationRating Int?
  timelinessRating Int?
  comment     String?
  isPublic    Boolean @default(true)
  createdAt   DateTime @default(now())

  @@index([subjectId])
  @@index([authorId])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

enum NotificationType {
  NEW_BRIEF_MATCH
  PROPOSAL_RECEIVED
  PROPOSAL_QUALIFIED
  PROPOSAL_SELECTED
  PROPOSAL_REJECTED
  DIRECT_HIRE_OFFER
  JOB_ASSIGNED
  REVISION_REQUESTED
  JOB_APPROVED
  PAYMENT_RELEASED
  PAYMENT_RECEIVED
  REVIEW_RECEIVED
  SUBSCRIPTION_RENEWAL
  SUBSCRIPTION_EXPIRED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ============================================================
// ADMIN / DISPUTES
// ============================================================

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_FOR_BRAND
  RESOLVED_FOR_CREATOR
  CLOSED
}

model Dispute {
  id           String        @id @default(cuid())
  jobId        String
  escrowId     String
  raisedById   String
  status       DisputeStatus @default(OPEN)
  reason       String
  details      String?
  evidence     String[]      @default([])
  resolution   String?
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([raisedById])
}

// ============================================================
// CHAT / MESSAGING
// ============================================================

model Conversation {
  id         String         @id @default(cuid())
  brandId    String
  brand      BrandProfile   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  creatorId  String
  creator    CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  campaignId String?
  campaign   Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  subject    String?
  messages   Message[]
  contracts         Contract[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([brandId, creatorId, campaignId])
  @@index([brandId])
  @@index([creatorId])
  @@index([campaignId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(name: "MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([isRead])
}


// ============================================================
// WALLET, CONTRACTS & ESCROW
// ============================================================

enum TransactionType {
  TOPUP
  ESCROW_LOCK
  ESCROW_RELEASE
  ESCROW_REFUND
  TIP_SENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ContractStatus {
  DRAFT
  PENDING_CREATOR_SIGN
  ACTIVE
  SUBMITTED
  COMPLETED
  CANCELLED
}

enum SubmissionStatus {
  PENDING_REVIEW
  AI_APPROVED
  AI_REJECTED
  BRAND_APPROVED
  BRAND_REJECTED
}

model BrandWallet {
  id           String                  @id @default(cuid())
  brandId      String                  @unique
  brand        BrandProfile            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  balanceKobo  Int                     @default(0)
  currency     String                  @default("NGN")
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  transactions BrandWalletTransaction[]
}

model BrandWalletTransaction {
  id          String            @id @default(cuid())
  walletId    String
  wallet      BrandWallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        TransactionType
  amountKobo  Int
  reference   String?           @unique
  description String?
  status      TransactionStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime          @default(now())

  @@index([walletId])
  @@index([reference])
}

model Contract {
  id              String         @id @default(cuid())
  conversationId  String
  conversation    Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  brandId         String
  brand           BrandProfile   @relation(name: "BrandContracts", fields: [brandId], references: [id], onDelete: Cascade)
  creatorId       String
  creator         CreatorProfile @relation(name: "CreatorContracts", fields: [creatorId], references: [id], onDelete: Cascade)
  campaignId      String?
  campaign        Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  deliverable     String
  platform        String
  deadline        DateTime
  amountKobo      Int
  currency        String         @default("NGN")
  revisions       Int            @default(2)
  usageRights     String?
  additionalTerms String?

  status          ContractStatus @default(DRAFT)
  brandSignedAt   DateTime?
  creatorSignedAt DateTime?

  escrowPayment    ContractEscrow?
  videoSubmissions VideoSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([creatorId])
  @@index([conversationId])
}

model ContractEscrow {
  id          String         @id @default(cuid())
  contractId  String         @unique
  contract    Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  brandId     String
  brand       BrandProfile   @relation(name: "BrandContractEscrows", fields: [brandId], references: [id])
  creatorId   String
  creator     CreatorProfile @relation(name: "CreatorContractEscrows", fields: [creatorId], references: [id])
  amountKobo  Int
  currency    String         @default("NGN")
  status      EscrowStatus   @default(HELD)
  lockedAt    DateTime       @default(now())
  releasedAt  DateTime?

  @@index([brandId])
  @@index([creatorId])
}

model VideoSubmission {
  id            String           @id @default(cuid())
  contractId    String
  contract      Contract         @relation(fields: [contractId], references: [id], onDelete: Cascade)
  creatorId     String
  creator       CreatorProfile   @relation(name: "CreatorVideoSubs", fields: [creatorId], references: [id])
  videoUrl      String
  socialPostUrl String?
  aiAnalysis    String?
  aiScore       Float?
  status        SubmissionStatus @default(PENDING_REVIEW)
  brandFeedback String?
  submittedAt   DateTime         @default(now())
  reviewedAt    DateTime?

  @@index([contractId])
  @@index([creatorId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Shortlist {
  id        String   @id @default(cuid())
  brandId   String
  creatorId String
  createdAt DateTime @default(now())

  brand   BrandProfile   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([brandId, creatorId])
  @@index([brandId])
  @@index([creatorId])
}

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}
